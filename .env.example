# Local development defaults (for quick start only)
PORT=3000
NODE_ENV=development

POSTGRES_DB=amenity_reservations
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_PORT=5432

# Local app run
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/amenity_reservations

# Docker app run (inside container network)
# Use this value for DATABASE_URL when running docker compose
DATABASE_URL_DOCKER=postgresql://postgres:postgres@db:5432/amenity_reservations

# Dedicated DB for integration tests
DATABASE_URL_TEST=postgresql://postgres:postgres@localhost:5432/amenity_reservations_test

JWT_ACCESS_SECRET=change_me_to_a_random_secret_min_32_chars
JWT_ACCESS_EXPIRES_IN=15m
BCRYPT_SALT_ROUNDS=12
